# Copy to .env — never commit .env (contains your operator mnemonic)

# Published testnet image (linux/amd64)
HOPE_PEER_IMAGE=public.ecr.aws/r8k0t0l9/hope-peer:testnet

# Apple Silicon Mac: uncomment to run the amd64 image via emulation
# DOCKER_PLATFORM=linux/amd64

# --- Incentives (optional) ---
# Valid BIP-39 24-word phrase. When set, full automation is enabled automatically.
HOPE_OPERATOR_MNEMONIC=

# Rewards address (optional; defaults to operator address)
PAYOUT_RECIPIENT=

# Human-readable label on chain (Network analytics)
NODE_LABEL=my-hope-peer

# Public P2P address (host:26656). Leave empty for auto-detect on cloud/VPS.
EXTERNAL_ADDRESS=
AUTO_DETECT_EXTERNAL_ADDRESS=true

MONIKER=hope-peer
CHAIN_ID=hope-testnet-2

# State sync uses host:port RPC with snapshots (HTTPS gateway /rpc alone is not enough).
# Default probes gateway first; override if your network blocks it.
# STATE_SYNC=true
# STATE_SYNC_RPC=3.21.91.67:26657

# Advanced: override chain metadata / peers (usually leave empty)
# SEEDS=
# PERSISTENT_PEERS=

# Testnet uses sync-proof-only liveness — no heartbeat txs required.
# AUTO_HEARTBEAT=false
